# Environment variables
.env

# Python cache
__pycache__/
*.pyc
*.pyo

# IDE
.vscode/
.idea/

# Virtual environment
.venv/

# Cached OHLCV data (large, refetchable, never committed)
data/

# Per-run artifacts inside results/ — keep per-campaign *.tsv files (and
# .gitkeep) so experiment logs persist in git and across CI runs; ignore
# logs and one-time backups.
results/*
!results/*.tsv
!results/.gitkeep
results/*.tsv.legacy
results/run.log
results/scan.log

# Legacy artifacts at the project root (anchored with leading / so they don't
# match files inside subfolders — e.g. /results.tsv ≠ results/results.tsv).
/results.tsv
/results.tsv.legacy
/run.log
trades.log
logs/

# promote.py scratch dir — holds candidate strategy file during validation
_promote_tmp/
