# Copy to .env and fill in. .env is gitignored; .env.example is committed.

# ──────────────────────────── Required ────────────────────────────
# OpenRouter API key — get one at https://openrouter.ai/keys
# OpenRouter is a unified API gateway: one key, any model from any provider
# (Anthropic, OpenAI, DeepSeek, Google, Mistral, etc.).
OPENROUTER_API_KEY=sk-or-v1-...

# Model used by loop.py to propose strategy mutations.
# Any slug from https://openrouter.ai/models works. Examples:
#   anthropic/claude-haiku-4-5     (default — cheap + fast)
#   anthropic/claude-sonnet-4-6    (smarter, ~10x cost)
#   anthropic/claude-opus-4-7      (smartest, ~50x cost)
#   openai/gpt-5
#   deepseek/deepseek-r1
#   google/gemini-2.5-pro
OPENROUTER_MODEL=anthropic/claude-haiku-4-5

# ──────────────────────── Loop / harness tuning ───────────────────
# val_sharpe (default) | calmar | dsr
OPTIMIZE_METRIC=val_sharpe

# Multiple-testing gate. 0 disables. Set to ~0.5 once you have 50+ trials.
DSR_GATE_THRESHOLD=0

# ────────────────────── What the loop optimizes ──────────────────
# Comma-separated parquet stems under data/ (no .parquet suffix).
#   N=1  → single mode (stricter MIN_TRADES=20)
#   N≥2  → basket mode (MIN_BASKET_TRADES=5, scored with overfit penalty:
#                       mean(sharpes) - BASKET_PENALTY * std(sharpes))
# Empty/unset → crypto/BTC_USDT_4h.
# Examples:
#   SYMBOLS=crypto/BTC_USDT_4h
#   SYMBOLS=stocks/TSLA_1d
#   SYMBOLS=stocks/TSLA_1d,stocks/NVDA_1d,stocks/AAPL_1d
SYMBOLS=
BASKET_PENALTY=0.5

# Strategy file the loop reads/writes/commits. Each campaign owns its own
# file so stocks and crypto evolve independently and can't overwrite each
# other's keeps. Defaults are derived from SYMBOLS prefix:
#   crypto/* → strategies/crypto.py
#   anything else → strategies/stocks.py
# Set this explicitly only if you want a non-default mapping.
STRATEGY_FILE=

# Commission per side (so 0.001 = 10 bps round-trip). Default models
# slippage + spread for liquid US large-caps and crypto. Lowering it
# invites "scalp the noise" overfits that bleed money in production.
COMMISSION=0.001

# ──────────────── Required for live_trade.py only ─────────────────
# Paper trading uses the alpaca-py SDK (https://github.com/alpacahq/alpaca-py).
# Get free paper keys: https://app.alpaca.markets/paper/dashboard/overview
#
# ALPACA_PAPER=True  → use paper keys (paper.alpaca.markets endpoint)
# ALPACA_PAPER=False → use LIVE keys (real money — requires --live to be set
#                      on the CLI as well; both must agree).
ALPACA_API_KEY=PK_PAPER_KEY_HERE
ALPACA_API_SECRET=PAPER_SECRET_HERE
ALPACA_PAPER=True

# Per-symbol cash budget (USD). Each BUY signal sizes to cash / last_close.
PAPER_PER_SYMBOL_CASH=10000

# Comma-separated tickers. Stocks use yfinance for bars; crypto uses
# alpaca-py CryptoHistoricalDataClient (free, no key needed for bars).
PAPER_WATCHLIST=SPY,QQQ,TSLA,NVDA
PAPER_CRYPTO_WATCHLIST=BTC/USD,ETH/USD

# ────────────────── Signal-alert scanner (scan.py) ────────────────
SCAN_WATCHLIST=SPY,QQQ,TSLA,NVDA,AAPL,MSFT
SCAN_LOOKBACK_DAYS=250
SCAN_FRESH_BARS=1
SCAN_INITIAL_CASH=10000
SCAN_WEBHOOK_URL=
