# Copy to .env and fill in. .env is gitignored; .env.example is committed.

# ──────────────────────────── Required ────────────────────────────
# OpenRouter API key — get one at https://openrouter.ai/keys
# OpenRouter is a unified API gateway: one key, any model from any provider
# (Anthropic, OpenAI, DeepSeek, Google, Mistral, etc.).
OPENROUTER_API_KEY=sk-or-v1-...

# Model used by loop.py to propose strategy mutations.
# Any slug from https://openrouter.ai/models works. Examples:
#   deepseek/deepseek-v4-flash     (default — cheap + fast)
#   anthropic/claude-sonnet-4-6    (smarter, ~10x cost)
#   anthropic/claude-opus-4-7      (smartest, ~50x cost)
#   openai/gpt-5
#   deepseek/deepseek-r1
#   google/gemini-2.5-pro
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# ──────────────────────── Loop / harness tuning ───────────────────
# Cap on each LLM reply (description + diff). Default 8000. Do not set below
# 4096 when using unified-diff mutations — large hunks truncate and fail to parse.
MAX_OUTPUT_TOKENS=8000

# Optimization signal (computed on TRAIN window — val acts as a holdout gate).
# train_sharpe (default) | train_calmar | train_dsr
OPTIMIZE_METRIC=train_sharpe

# Allowed val-Sharpe regression on a kept improvement. 0 = strict.
VAL_TOLERANCE=0.10

# Per-period regime gate: worst val sub-period must beat this Sharpe floor.
SUB_PERIOD_MIN_SHARPE=-0.5

# Number of equal-length sub-periods to slice val into for regime scoring.
# 4 ≈ yearly on a 3-4y val window; the loop also rejects when more than half
# of these sub-periods are negative.
SUB_PERIODS=4

# Leading bars dropped from every window slice (train/val/lockbox) so EMA/ADX/
# ATR/Donchian indicator state is stable before any trade signal counts.
# 150 covers ~3× the longest current indicator lookback (slow EMA = 45).
WARMUP_BARS=150

# Multiple-testing gate. 0 disables. Set to ~0.5 once you have 50+ trials.
DSR_GATE_THRESHOLD=0

# Minimum post-purge bars in the lockbox slice before promote.py will run.
# Below this, promote.py refuses (records REFUSED in promotions.tsv) so
# live_trade.py can't be cleared with a noisy holdout. 150 ≈ 6 months of
# daily stock history or ~25 days of 4h crypto — enough for a meaningful
# Sharpe and at least 20 trades on a moderate-frequency strategy.
LOCKBOX_MIN_BARS=150

# ────────────────────── Campaign selection ───────────────────────
# All per-campaign settings (SYMBOLS, VAL_START/END, STRATEGY_FILE,
# COMMISSION, etc.) live in configs.toml on main. Set CAMPAIGN here and
# everything else is loaded automatically.
#   crypto  → strategies/crypto.py, BTC 4h, val 2022-2024
#   stocks  → strategies/stocks.py, TSLA/NVDA/PYPL basket, val 2020-2024
CAMPAIGN=crypto

# Local development: checkout the dev branch. One-off overrides:
# SYMBOLS=crypto/BTC_USDT_4h
# VAL_START=2021-01-01
# VAL_END=2024-12-31
# COMMISSION=0.001
# STRATEGY_FILE=strategies/crypto.py

# Basket overfit penalty (only relevant in basket/multi-symbol mode).
BASKET_PENALTY=0.5

# ──────────────── Required for live_trade.py only ─────────────────
# Paper trading uses the alpaca-py SDK (https://github.com/alpacahq/alpaca-py).
# Get free paper keys: https://app.alpaca.markets/paper/dashboard/overview
#
# ALPACA_PAPER=True  → use paper keys (paper.alpaca.markets endpoint)
# ALPACA_PAPER=False → use LIVE keys (real money — requires --live to be set
#                      on the CLI as well; both must agree).
ALPACA_API_KEY=PK_PAPER_KEY_HERE
ALPACA_API_SECRET=PAPER_SECRET_HERE
ALPACA_PAPER=True

# Per-symbol cash budget (USD). Each BUY signal sizes to cash / last_close.
PAPER_PER_SYMBOL_CASH=10000

# Comma-separated tickers. Stocks use yfinance for bars; crypto uses
# alpaca-py CryptoHistoricalDataClient (free, no key needed for bars).
PAPER_WATCHLIST=SPY,QQQ,TSLA,NVDA
PAPER_CRYPTO_WATCHLIST=BTC/USD,ETH/USD

