broker = "Alpaca"

MARKET=24/7
POLYGON_API_KEY="cSmAoo3K3Qmg9alqjjKTAzh_byUfWzz8"

# Lumibot Configs
BACKTESTING_START=2025-01-01
BACKTESTING_END=2025-09-19
IS_BACKTESTING=True

# Optimizer Configs
SYMBOL=AMPX
DATA_TIMEFRAME=day #sleeptime for lumibot
AGGREGATE_TO_DAILY=false

# Trading Configs
INITIAL_CAPITAL=100000
CASH_AT_RISK=1
PROBABILITY_THRESHOLD=0.70

# =============================================================================
# STRATEGY CONFIGURATION
# =============================================================================
# Whether to use optimized parameters (if available)
USE_OPTIMIZED_PARAMS=true

# =============================================================================
# OPTIMIZATION CONFIGURATION
# =============================================================================
# Maximum parameter combinations to test (significantly increased for better coverage)
# Previous default: 500, New default: 2000
# Higher values = better optimization but longer runtime
MAX_COMBINATIONS=1000
# =============================================================================
# DATA CONFIGURATION
# =============================================================================
# Maximum data set size (in bars, not necessarily days)
# - For daily data: 730 bars = 730 days (Polygon free tier limit)
# - For hourly data: 4745 bars = 730 days * 6.5 trading hours
# - METHOD 1: Uses this as preferred amount, auto-adjusts if needed
# - METHOD 2: Uses full available data window regardless
MAX_DATA_SET=730

# Optimization strategy: 'true' = prioritize total return, 'false' = balanced approach
# Return-focused: 70% return, 10% win rate, 10% profit factor, 5% sharpe, 5% drawdown
# Balanced: 40% return, 20% win rate, 20% profit factor, 10% sharpe, 10% drawdown
OPTIMIZE_FOR_RETURN=true
LOG_LEVEL=INFO

# Number of CPU cores for parallel processing (empty/None = sequential processing)
N_JOBS=4

# =============================================================================
# RANDOMIZATION CONFIGURATION
# =============================================================================
# Control randomization in parameter optimization
# - Leave commented out (or remove) for random results each run (good for exploration)
# - Set to a number for reproducible results (good for debugging/comparison)
# RANDOM_SEED=42

# Walk-forward analysis periods (empty = disabled, number = enabled with N periods)
# Tests top parameters across multiple time periods to avoid overfitting
WALK_FORWARD_PERIODS=

# =============================================================================
# TIMING ALIGNMENT CONFIGURATION (Fix Look-Ahead Bias)
# =============================================================================
# Trade execution time for intraday alignment (empty/None = use daily close, HH:MM = intraday)
# This fixes the critical timing mismatch where optimization uses daily close
# but the real strategy trades at 10:30 AM
SIMULATION_TRADE_TIME=10:30

# Fallback behavior when exact trade time is not available
# Options: 'closest' (use nearest hour), 'skip' (skip that day), 'previous' (use previous day's close)
MISSING_TIME_STRATEGY=closest
